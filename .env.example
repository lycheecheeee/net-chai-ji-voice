# =============================================================================
# Net 知己 AI 財經平台 - 環境變量配置
# =============================================================================

# Node.js 環境
NODE_ENV=development

# =============================================================================
# BigModel API (智譜AI) - 用於聊天和廣播腳本生成
# =============================================================================
# 獲取方式：https://open.bigmodel.cn/
BIGMODEL_API_KEY=your_bigmodel_api_key_here
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# =============================================================================
# Cantonese.ai API - 用於粵語語音合成
# =============================================================================
# 獲取方式：https://cantonese.ai/
CANTONESE_API_KEY=your_cantonese_api_key_here
CANTONESE_API_URL=https://cantonese.ai/api/tts

# =============================================================================
# Vercel 部署配置
# =============================================================================
# Vercel 自動設置的環境變量
VERCEL_URL=
VERCEL_PROJECT_NAME=net-zhi-ji-voice-api-123

# =============================================================================
# 數據庫配置 (如使用 Prisma)
# =============================================================================
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# =============================================================================
# 開發環境配置
# =============================================================================
# 本地開發端口
PORT=3000

# 調試模式
DEBUG=false

# =============================================================================
# 安全配置
# =============================================================================
# JWT 密鑰 (如使用認證)
# JWT_SECRET=your_jwt_secret_here

# API 密鑰 (如需要)
# API_SECRET_KEY=your_api_secret_key_here

# =============================================================================
# 第三方服務配置
# =============================================================================
# Google Analytics (可選)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Sentry 錯誤追蹤 (可選)
# SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# 注意事項
# =============================================================================
# 1. 複製此文件為 .env 並填入實際值
# 2. .env 文件已被 .gitignore 忽略，不會提交到版本控制
# 3. 生產環境請使用強密碼和安全的 API 密鑰
# 4. 定期輪換 API 密鑰以確保安全性
# 5. 確保至少配置 BIGMODEL_API_KEY 和 CANTONESE_API_KEY
# 6. BigModel 用於 AI 聊天和廣播腳本生成
# 7. Cantonese.ai 用於粵語語音合成
